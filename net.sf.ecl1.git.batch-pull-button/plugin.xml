<?xml version="1.0" encoding="UTF-8"?>
<?eclipse version="3.4"?>
<plugin>
	<extension
	      point="org.eclipse.ui.commands">
	      <command
             id="net.sf.ecl1.git.batch-pull-button.command"
             name="Batch Git Pull Command" />
	      <command
             id="net.sf.ecl1.git.pr.command"
             name="Create Merge Request" />
	</extension>
	<extension
	      point="org.eclipse.ui.handlers">
    	<handler
          	commandId="net.sf.ecl1.git.batch-pull-button.command"
          	class="net.sf.ecl1.git.GitBatchPullHandler" />
    	<handler
          	commandId="net.sf.ecl1.git.pr.command"
          	class="net.sf.ecl1.git.pr.PullRequestHandler" />
	</extension>
	<extension
	      point="org.eclipse.ui.menus">
	      <menuContribution
             locationURI="toolbar:org.eclipse.ui.main.toolbar">
          <toolbar
                id="net.sf.ecl1.git.batch-pull-button.toolbar1"
                label="ecl1 Tools">
             <command
                   commandId="net.sf.ecl1.git.batch-pull-button.command"
                   icon="icons/pull-all.gif"
                   label="Batch Pull"
                   style="push">
             </command>
             <command
                   commandId="net.sf.ecl1.git.pr.command"
                   icon="icons/pull-all.gif"
                   label="Create Merge Request"
                   style="push"
                   tooltip="Create a Gitlab Merge Request for the selected project">
             </command>
          </toolbar>
	      </menuContribution>
	</extension>
</plugin>
